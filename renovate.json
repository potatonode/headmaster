{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies",
      "groupSlug": "rust-deps"
    },
    {
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "kube",
        "k8s-openapi",
        "k8s-openapi-ext",
        "envtest"
      ],
      "groupName": "kube ecosystem",
      "groupSlug": "kube-ecosystem",
      "separateMajorMinor": false
    },
    {
      "description": "TODO: remove when k8s-openapi-ext releases 0.28 support — kube 4.x requires k8s-openapi 0.28, which k8s-openapi-ext does not yet support; upgrade the whole kube ecosystem together",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["kube"],
      "allowedVersions": "<4.0.0"
    },
    {
      "description": "TODO: remove when k8s-openapi-ext releases 0.28 support — upgrade kube and k8s-openapi together in one PR",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["k8s-openapi"],
      "allowedVersions": "<0.28.0"
    },
    {
      "matchPackageNames": ["ghcr.io/juanfont/headscale"],
      "groupName": "headscale image",
      "groupSlug": "headscale-image"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^chart/values\\.yaml$"],
      "matchStrings": [
        "headscaleImage:\\s*(?<depName>[^:\\n]+):(?<currentValue>[^\\n]+)",
        "proxyImage:\\s*(?<depName>[^:\\n]+):(?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^Taskfile\\.yml$"],
      "matchStrings": [
        "--image (?<depName>rancher/k3s):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/verify\\.yml$"],
      "matchStrings": [
        "k3d-io/k3d/releases/download/(?<currentValue>[^/]+)/k3d-linux-amd64"
      ],
      "depNameTemplate": "k3d-io/k3d",
      "datasourceTemplate": "github-releases"
    }
  ]
}
